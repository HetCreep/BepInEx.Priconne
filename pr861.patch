             if (DumpDummyAssemblies.Value)
             {
-                var dummyPath = Path.Combine(Paths.BepInExRootPath, "dummy");
+                var dummyPath = Path.Combine(IL2CPPBasePath, "dummy");
                 Directory.CreateDirectory(dummyPath);
